### OpenDXP — environment template
###
### Usage:
###   cp .env.example .env.local   # local development (gitignored)
###   cp .env.example .env         # or .env (also gitignored)
###
### Loaded by Symfony Dotenv in this order (later overrides earlier):
###   .env             — committed skeleton (gitignored in this repo)
###   .env.<APP_ENV>   — per-environment defaults
###   .env.local       — local overrides (gitignored, use for secrets)
###
### ⚠ DO NOT put real secrets here — this file is committed.

APP_ENV=dev
APP_DEBUG=true
OPENDXP_DEV_MODE=false

# ── Database (MySQL) ────────────────────────────────────
DB_HOST=infivea-mysql
DB_NAME=pimcore
DB_USER=pimcore
DB_PASSWORD=pimcore
DB_PORT=3306
DB_SERVER_VERSION=8.0.26

# ── DeepL translation ───────────────────────────────────
# Free tier: https://api-free.deepl.com/v2/translate + key with :fx suffix
# Pro tier:  https://api.deepl.com/v2/translate     + key without suffix
DEEPL_AUTH_KEY=
DEEPL_GLOSSARY_KEY=
DEEPL_ENDPOINT=https://api.deepl.com/v2/translate
ADMIN_NOTIFICATION_EMAIL=

# ── Vendure Bridge ──────────────────────────────────────
# Reference only: where OpenDXP can reach Vendure.
VENDURE_HOST=http://172.19.0.1:3004

# PIMCORE_API_KEY validates incoming x-api-key on /api/vendure/* endpoints.
# Naming kept for cross-service compatibility (Vendure + Storefront use the same name).
# MUST match Vendure's PIMCORE_API_KEY and Storefront's PIMCORE_API_KEY.
PIMCORE_API_KEY=

# PIMCORE_BRIDGE_WEBHOOK_SECRET is the bi-directional shared secret for webhooks
# between OpenDXP and Vendure (X-Webhook-Secret header on both sides).
# MUST match Vendure's PIMCORE_BRIDGE_WEBHOOK_SECRET.
PIMCORE_BRIDGE_WEBHOOK_SECRET=

# ── Storefront cache invalidation (OpenDXP → Storefront) ──
# OpenDXP sends POST {STOREFRONT_URL}/api/cache-invalidate with x-cache-secret
# header after content changes (navigation, translations, WebsiteConfiguration).
# MUST match Storefront's CACHE_INVALIDATE_SECRET.
STOREFRONT_URL=
CACHE_INVALIDATE_SECRET=

# ── Symfony Messenger + RabbitMQ ────────────────────────
MESSENGER_DSN=amqp://guest:guest@infivea-rabbitmq:5672/%2f/messages
AMQP_HOST=infivea-rabbitmq
AMQP_PORT=5672
AMQP_USER=guest
AMQP_PASSWORD=guest
