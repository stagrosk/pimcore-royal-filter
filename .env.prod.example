### OpenDXP — Production .env template (Ploi)
###
### Site: pim.infivea.com
### Copy into Ploi → Site → Environment and replace __REPLACE_ME__ placeholders.
### Do NOT commit a real .env.prod with secrets.

APP_ENV=prod
APP_DEBUG=false
OPENDXP_DEV_MODE=false
APP_TIMEZONE=Europe/Bratislava

# ── Database (MySQL) ────────────────────────────────────
DB_HOST=127.0.0.1
DB_NAME=pimcore_royalfilter
DB_USER=pimcore_royalfilter
DB_PASSWORD=__REPLACE_ME__
DB_PORT=3306
DB_SERVER_VERSION=8.0.26

# ── DeepL translation ───────────────────────────────────
DEEPL_AUTH_KEY=__REPLACE_ME__
DEEPL_GLOSSARY_KEY=
DEEPL_ENDPOINT=https://api.deepl.com/v2/translate
ADMIN_NOTIFICATION_EMAIL=

# ── Vendure Bridge ──────────────────────────────────────
VENDURE_HOST=https://vendure.infivea.com
# Cross-service shared keys (named PIMCORE_* for backwards compat with Vendure/Storefront):
PIMCORE_API_KEY=__REPLACE_ME__
PIMCORE_BRIDGE_WEBHOOK_SECRET=__REPLACE_ME__

# ── Storefront cache invalidation ───────────────────────
STOREFRONT_URL=https://storefront.infivea.com
CACHE_INVALIDATE_SECRET=__REPLACE_ME__

# ── Symfony Messenger + RabbitMQ ────────────────────────
MESSENGER_DSN=amqp://guest:guest@127.0.0.1:5672/%2f/messages
AMQP_HOST=127.0.0.1
AMQP_PORT=5672
AMQP_USER=guest
AMQP_PASSWORD=guest

# ── OpenDXP password salt BC ────────────────────────────
# Optional explicit env override (config/config.yaml hardcodes "pimcore" already).
# OPENDXP_PASSWORD_SALT=pimcore
