{
  "name": "stagro/pimcore-royal-filter",
  "type": "project",
  "license": "GPL-3.0-or-later",
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "process-timeout": 0,
    "allow-plugins": {
      "symfony/runtime": true
    }
  },
  "repositories": [
    {
      "type": "path",
      "url": "lib/pimcore-headless-content-bundle"
    },
    {
      "type": "vcs",
      "url": "git@github.com:elevantiq/pimcore-deepl.git"
    },
    {
      "type": "vcs",
      "url": "git@github.com:elevantiq/pimcore-translation-bundle.git"
    }
  ],
  "prefer-stable": true,
  "require": {
    "php": ">=8.2",
    "doctrine/doctrine-migrations-bundle": "^3.4",
    "doctrine/orm": "^2.19",
    "illuminate/collections": "*",
    "phpclassic/php-shopify": "^1.2",
    "pimcore/admin-ui-classic-bundle": "^1.0",
    "pimcore/data-hub": "^1.8",
    "pimcore/pimcore": "^11.0",
    "stagro/pimcore-headless-content-bundle": "dev-main",
    "symfony/dotenv": "^6.4",
    "symfony/runtime": "^6.4",
    "elevantiq/pimcore-deepl": "^11.0",
    "elevantiq/pimcore-translation-bundle": "^11.0"
  },
  "require-dev": {
    "codeception/codeception": "^5.0.3",
    "codeception/module-symfony": "^3.1.0"
  },
  "suggest": {
    "pimcore/data-hub": "Universal data interface for GraphQL, CSV and other formats"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/",
      "Pimcore\\Model\\DataObject\\": "var/classes/DataObject"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-create-project-cmd": "Pimcore\\Composer::postCreateProject",
    "post-install-cmd": [
      "Pimcore\\Composer::postInstall",
      "@pimcore-scripts"
    ],
    "post-update-cmd": [
      "Pimcore\\Composer::postUpdate",
      "@pimcore-scripts"
    ],
    "pimcore-scripts": [
      "Pimcore\\Composer::clearCache",
      "Pimcore\\Composer::installAssets"
    ]
  }
}
