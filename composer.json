{
  "name": "stagro/opendxp-infivea",
  "type": "project",
  "license": "GPL-3.0-or-later",
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "process-timeout": 0,
    "allow-plugins": {
      "cweagans/composer-patches": true,
      "symfony/runtime": true,
      "wikimedia/composer-merge-plugin": true
    }
  },
  "extra": {
    "patches": {
      "open-dxp/data-hub-bundle": {
        "Init container default to null (avoids 'must not be accessed before initialization' on direct construction in Block::getFieldType)": "patches/data-hub-container-default-null.patch"
      }
    },
    "composer-exit-on-patch-failure": true
  },
  "repositories": [
    {
      "type": "path",
      "url": "lib/opendxp-headless-content-bundle"
    },
    {
      "type": "path",
      "url": "lib/opendxp-vendure-bridge-bundle"
    },
    {
      "type": "path",
      "url": "lib/opendxp-deepl-bundle"
    },
    {
      "type": "path",
      "url": "lib/opendxp-translation-bundle"
    }
  ],
  "prefer-stable": true,
  "minimum-stability": "dev",
  "require": {
    "php": "~8.3.0 || ~8.4.0",
    "cweagans/composer-patches": "^1.7",
    "doctrine/doctrine-migrations-bundle": "^3.4",
    "doctrine/orm": "^2.19 || ^3.0",
    "guzzlehttp/guzzle": "^7.0",
    "illuminate/collections": "*",
    "open-dxp/admin-bundle": "^1.0",
    "open-dxp/data-hub-bundle": "^1.0",
    "open-dxp/opendxp": "^1.3",
    "stagro/opendxp-deepl-bundle": "dev-main",
    "stagro/opendxp-headless-content-bundle": "dev-main",
    "stagro/opendxp-translation-bundle": "dev-main",
    "stagro/opendxp-vendure-bridge-bundle": "dev-main",
    "symfony/dotenv": "^7.4",
    "symfony/runtime": "^7.4"
  },
  "require-dev": {
    "codeception/codeception": "^5.0.3",
    "codeception/module-symfony": "^3.1.0"
  },
  "suggest": {
    "open-dxp/data-hub-bundle": "Universal data interface for GraphQL, CSV and other formats"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/",
      "OpenDxp\\Model\\DataObject\\": "var/classes/DataObject"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-create-project-cmd": "OpenDxp\\Composer::postCreateProject",
    "post-install-cmd": [
      "OpenDxp\\Composer::postInstall",
      "@opendxp-scripts"
    ],
    "post-update-cmd": [
      "OpenDxp\\Composer::postUpdate",
      "@opendxp-scripts"
    ],
    "opendxp-scripts": [
      "OpenDxp\\Composer::clearCache",
      "OpenDxp\\Composer::installAssets"
    ]
  }
}
