{
  "name": "stagro/opendxp-headless-content-bundle",
  "description": "OpenDXP headless content bundle",
  "type": "opendxp-bundle",
  "license": "GPL-3.0-or-later",
  "authors": [
    {
      "name": "Stagro s.r.o",
      "email": "martin@stagro.sk"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "php": "~8.3.0 || ~8.4.0",
    "open-dxp/opendxp": "^1.0",
    "cocur/slugify": "^4.6"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "OpendxpHeadlessContentBundle\\": "src/"
    }
  },
  "extra": {
    "opendxp": {
      "bundles": [
        "OpendxpHeadlessContentBundle\\OpendxpHeadlessContentBundle"
      ]
    }
  }
}
