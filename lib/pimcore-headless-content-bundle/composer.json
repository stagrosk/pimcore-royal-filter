{
  "name": "stagro/pimcore-headless-content-bundle",
  "description": "Pimcore headless content",
  "type": "pimcore-bundle",
  "authors": [
    {
      "name": "Stagro s.r.o",
      "email": "martin@stagro.sk"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
